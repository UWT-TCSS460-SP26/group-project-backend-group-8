PORT=3000
TMDB_API_KEY=your_tmdb_api_key_here

# Auth² (auth-squared) — token issuance is owned by the shared identity
# provider. AUTH_ISSUER is the issuer URL; API_AUDIENCE is this group's
# audience name as registered with auth-squared.
AUTH_ISSUER=https://tcss-460-iam.onrender.com
API_AUDIENCE=group-8-api

# Comma-separated list of allowed origins for CORS preflight. `*` means any.
CORS_ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL="postgres://[DB-USER].[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres"