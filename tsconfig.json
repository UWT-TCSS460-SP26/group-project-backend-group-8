{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/generated/prisma": ["prisma/src/generated/prisma"],
      "@/generated/prisma/client": ["prisma/src/generated/prisma/client"]
    }
  },
  "include": ["src/**/*", "prisma/src/generated/prisma/client"],
  "exclude": ["node_modules", "dist", "tests"]
}
